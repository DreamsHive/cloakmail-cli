{
	"name": "cloakmail-cli",
	"version": "0.1.0",
	"description": "An official CloakMail CLI",
	"type": "module",
	"bin": {
		"cloakmail-cli": "./src/index.ts"
	},
	"scripts": {
		"dev": "seed dev",
		"build": "seed build",
		"compile": "seed build --compile --outfile cloakmail-cli",
		"test": "vitest run",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"dependencies": {
		"@seedcli/core": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@seedcli/cli": "^1.1.1",
		"@seedcli/testing": "^1.1.1",
		"@types/node": "^24.0.0",
		"tsx": "^4.19.0",
		"vitest": "^3.2.0",
		"typescript": "^5.9.0"
	}
}
